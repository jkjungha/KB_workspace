<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.scoula.travel.dao.TravelDao">
    <select id="getTotalCount" resultType="int"><![CDATA[SELECT COUNT(*) FROM tbl_travel]]></select>
    <select id="getTravelList" resultType="TravelVO"><![CDATA[SELECT * FROM tbl_travel ORDER BY district, title limit #{start}, #{size}]]></select>
